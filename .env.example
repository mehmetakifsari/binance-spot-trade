APP_ENV=development

# Public URLs / domains (Coolify)
FRONTEND_BASE_URL=https://trade.visupanel.com
BACKEND_BASE_URL=https://api-trade.visupanel.com
CORS_ALLOWED_ORIGINS=https://trade.visupanel.com,http://localhost:8000

# Bridge service
BINANCE_STREAM=wss://stream.binance.com:9443/ws/btcusdt@trade
N8N_WEBHOOK_URL=http://n8n:5678/webhook/visutrade-signal
BRIDGE_HTTP_PORT=8001

# Backend + dashboard
BACKEND_PORT=8000
DB_HOST=postgres
DB_PORT=5432
DB_NAME=visutrade
DB_USER=visutrade
DB_PASSWORD=visutrade

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional explanation layer only (never trade decision)
OPENAI_API_KEY=

# Trading defaults
STARTING_BALANCE_USDT=15
NORMAL_BUY_USDT=3
PANIC_BUY_USDT=1.5
TRADE_COOLDOWN_SECONDS=300

# MongoDB auth storage
MONGODB_URI=mongodb://mongo:27017
MONGODB_AUTH_DB=visutrade_auth
MONGODB_AUTH_COLLECTION=admin_users
